{
	"name": "casai",
	"version": "0.4.1",
	"description": "Orchestrate AI agent workflows with Nunjucks-style text templates that implicitly run async tasks in parallel",
	"author": "Angel Popov<geleto@gmail.com>",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/geleto/casai.git"
	},
	"homepage": "https://github.com/geleto/casai#readme",
	"bugs": {
		"url": "https://github.com/geleto/casai/issues"
	},
	"keywords": [
		"ai",
		"agent",
		"vercel",
		"template",
		"async",
		"parallel",
		"concurrency",
		"llm",
		"orchestration",
		"workflow",
		"nunjucks",
		"templates"
	],
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"build:tsc": "tsc -p tsconfig.build.json",
		"clean": "rimraf dist",
		"lint": "eslint src tests",
		"typecheck": "tsc --noEmit",
		"test": "mocha",
		"test:file": "mocha --no-config --node-option loader=ts-node/esm --require dotenv/config",
		"test:watch": "mocha --watch",
		"test-type": "eslint tests/type-safety",
		"start": "tsx examples/story.ts"
	},
	"devDependencies": {
		"@ai-sdk/anthropic": "^3.0.72",
		"@ai-sdk/openai": "^3.0.54",
		"@babel/core": "^7.29.0",
		"@babel/preset-env": "^7.29.2",
		"@eslint/js": "^10.0.1",
		"@types/chai": "^5.2.3",
		"@types/chai-as-promised": "^8.0.2",
		"@types/mocha": "^10.0.10",
		"@types/node": "^25.6.0",
		"@typescript-eslint/eslint-plugin": "^8.59.1",
		"@typescript-eslint/parser": "^8.59.1",
		"ai": "^6.0.169",
		"chai": "^6.2.2",
		"chai-as-promised": "^8.0.2",
		"dotenv": "^17.4.2",
		"eslint": "^10.2.1",
		"mocha": "^11.7.5",
		"rimraf": "^6.1.3",
		"tsx": "^4.21.0",
		"typescript-eslint": "^8.59.1"
	},
	"engines": {
		"node": ">=22.0.0",
		"npm": ">=9.0.0"
	},
	"dependencies": {
		"cascada-engine": "^0.4.0",
		"ts-node": "^10.9.2",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"ai": "^6.0.0"
	},
	"overrides": {
		"mocha": {
			"diff": "^9.0.0",
			"serialize-javascript": "^7.0.5"
		}
	}
}
